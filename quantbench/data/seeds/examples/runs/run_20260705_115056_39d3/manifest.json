      "tool": "run_signal_backtest",
      "args": {
        "code": "def compute(df: pd.DataFrame) -> pd.Series:\n    # 计算50日均线和200日均线\n    ma50 = df['close'].rolling(window=50).mean()\n    ma200 = df['close'].rolling(window=200).mean()\n    \n    # 信号：1 = 金叉做多（50上穿200），0 = 死叉空仓（50下穿200）\n    # 用shift(1)确保因果性：用前一天的均线位置判断今天开盘时的信号\n    prev_ma50 = ma50.shift(1)\n    prev_ma200 = ma200.shift(1)\n    \n    # 金叉：前一日50<200，当日50>200\n    golden_cross = (prev_ma50 <= prev_ma200) & (ma50 > ma200)\n    # 死叉：前一日50>200，当日50<200\n    death_cross = (prev_ma50 >= prev_ma200) & (ma50 < ma200)\n    \n    # 初始化信号为NaN（无持仓直到第一个信号）\n    signal = pd.Series(0.0, index=df.index)\n    \n    # 记录持仓状态：使用迭代来保持因果性\n    position = 0.0\n    for i in range(len(df)):\n        if i < 200:  # 需要200根K线才能计算均线\n            continue\n        if golden_cross.iloc[i]:\n            position = 1.0\n        elif death_cross.iloc[i]:\n            position = 0.0\n        signal.iloc[i] = position\n    \n    return signal",
        "cost_bps": 5
      },
