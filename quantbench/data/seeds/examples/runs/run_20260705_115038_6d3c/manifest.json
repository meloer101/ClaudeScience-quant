        "code": "def compute(df: pd.DataFrame) -> pd.Series:\n    close = df['close']\n    delta = close.diff()\n    gain = delta.where(delta > 0, 0.0)\n    loss = (-delta).where(delta > 0, 0.0)\n    avg_gain = gain.rolling(14).mean()\n    avg_loss = loss.rolling(14).mean()\n    rs = avg_gain / avg_loss\n    rsi = 100 - (100 / (1 + rs))\n    # Mean reversion signal: RSI < 30 => long (+1), RSI > 70 => short (-1), else flat (0)\n    signal = pd.Series(0.0, index=df.index)\n    signal[rsi < 30] = 1.0\n    signal[rsi > 70] = -1.0\n    return signal",
